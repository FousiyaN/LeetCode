class Solution(object):
    def isPalindrome(self, s):
        new = ""
        for word in s:
            if word.isalnum():
                new += word.lower()
        first = 0
        last = len(new)-1
        while first<last:
            if new[first]!= new[last]:
             return False
            first+=1
            last-=1
        return True
