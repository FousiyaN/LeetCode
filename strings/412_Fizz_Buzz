class Solution(object):
    def fizzBuzz(self, n):
        newlist = []
        for i in range(1,n+1):
            if (i%3==0 and i%5==0):
                newlist.append("FizzBuzz")
            elif i%3==0:
                newlist.append("Fizz")
            elif(i%5==0):
                newlist.append("Buzz")
            else:
                newlist.append(str(i))
        return newlist
